# ── Non-sensitive config (commit this, no secrets) ───────────────────────────

# Offer URL to scrape
OFFER_URL=https://octopus.energy/dashboard/new/accounts/YOUR_ACCOUNT/octoplus/partner/offer-group/925

# PostgreSQL connection
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=octoscrape
POSTGRES_USER=octoscrape


# ── Secrets (manage via Infisical, NOT stored in this file) ───────────────────
#
# Add these to your Infisical project (project name: octopus):
#
#   OCTOPUS_EMAIL        your Octopus Energy login email
#   OCTOPUS_PASSWORD     your Octopus Energy password
#   OCTOPUS_API_KEY      sk_live_xxxx  (Account → Personal details → API access)
#   POSTGRES_PASSWORD    strong random password for the database
#   SECRET_KEY           strong random string for internal signing
#
# To run locally with Infisical injecting secrets:
#   infisical run --env=dev -- docker compose up -d
#
# To run on a server:
#   infisical run --env=prod -- docker compose up -d
